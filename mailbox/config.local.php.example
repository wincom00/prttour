<?php
// ── 비밀값 템플릿 ──────────────────────────────────────────────
// 이 파일을 config.local.php 로 복사한 뒤 실제 값을 채운다.
// config.local.php 는 .gitignore 로 제외되어 git 에 올라가지 않는다.
// config.php 가 define 가드보다 먼저 이 파일을 로드하므로, 여기서 define 한
// 값이 config.php 의 빈 기본값을 덮어쓴다.
//
// ⚠ MBX_TOKEN_KEY 를 바꾸면 기존에 저장된 OAuth 토큰을 복호화할 수 없어
//   모든 계정을 다시 연결해야 한다.

// Google OAuth 클라이언트 시크릿 (Google Cloud 콘솔 > 사용자 인증 정보)
if (!defined('MBX_GOOGLE_CLIENT_SECRET')) {
    define('MBX_GOOGLE_CLIENT_SECRET', '');
}

// Microsoft OAuth 클라이언트 시크릿 (Entra 앱 등록, 사용 시)
if (!defined('MBX_MS_CLIENT_SECRET')) {
    define('MBX_MS_CLIENT_SECRET', '');
}

// OAuth 토큰 저장 암호화 키 (AES-256-GCM, 64 hex 문자 권장).
// 예: openssl rand -hex 32  로 생성. 한 번 정하면 변경하지 말 것.
if (!defined('MBX_TOKEN_KEY')) {
    define('MBX_TOKEN_KEY', '');
}
